# ════════════════════════════════════════════════════════════════
#  server_secrets.cfg.example  —  TEMPLATE versionado (sem valores reais).
#  Copiar para  server_secrets.cfg  e preencher.  server_secrets.cfg
#  está no .gitignore e NUNCA deve ser committado.
# ════════════════════════════════════════════════════════════════

set mysql_connection_string "server=<HOST>;database=<DB>;userid=<USER>;password=<PASS>;charset=utf8mb4_general_ci"

sv_licenseKey "<CFX_LICENSE_KEY>"

set steam_webApiKey "<STEAM_WEB_API_KEY>"

set discord_bot_token "Bot <DISCORD_BOT_TOKEN>"
# set discord_bot_token_perms "Bot <DISCORD_BOT_TOKEN_2>"

set discord_guild_id   "<GUILD_ID>"
set discord_staff_id   "<ROLE_ID>"
set discord_dev_id     "<ROLE_ID>"
set discord_intern_id  "<ROLE_ID>"
set discord_vpn_id     "<ROLE_ID>"
set discord_civil_id   "<ROLE_ID>"

set ipapi_key "<IP_API_PRO_KEY>"

# Webhooks (um set por canal; ler nos scripts via GetConvar)
# set webhook_entity "https://discord.com/api/webhooks/..."
