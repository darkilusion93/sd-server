RegisterCommand('migrateorgs', function(source, args, rawCommand)
    if source ~= 0 then return end

    local result = MySQL.Sync.fetchAll('SELECT * FROM jobs')

    if result == nil then return end

    table.insert(result, {name = 'swat'})
    table.insert(result, {name = 'sheriff'})

	for i=1, #result, 1 do
        local identifier = result[i].name

        local items = MySQL.Sync.fetchAll('SELECT * FROM addon_inventory_items WHERE inventory_name = @identifier', {
            ['@identifier'] = "society_"..identifier
        })

