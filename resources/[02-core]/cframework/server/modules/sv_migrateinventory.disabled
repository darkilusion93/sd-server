            ['@identifier'] = "society_"..identifier
        })[1]

        local datastore = MySQL.Sync.fetchAll('SELECT * FROM datastore_data WHERE name = @identifier', {
            ['@identifier'] = "society_"..identifier
        })[1]

        if datastore == nil then
            datastore = {data = "[]"}
        end

        local inventory  = items or {}
        local loadout    = json.decode(datastore.data or "[]").weapons or {}
        local blackMoney = 0

        if black_money ~= nil then
            blackMoney = black_money.money
        end

        local newInventory = {}
        local currentSlot = 1

        if blackMoney > 0 then
            table.insert(newInventory, {
                name   = 'black_money',
                count = blackMoney,
                metadata = {},
                slot   = currentSlot
            })

            currentSlot += 1
        end

        for key, item in pairs(inventory) do
            if item.count > 0 then
                table.insert(newInventory, {
                    name   = item.name,
                    count = item.count,
                    metadata = {},
                    slot   = currentSlot
