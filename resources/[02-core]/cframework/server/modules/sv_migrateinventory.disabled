RegisterCommand("migrateinventories", function(source, args, rawCommand)
    if source ~= 0 then return end

    local result = MySQL.Sync.fetchAll('SELECT * FROM inventories')

    if result == nil then return end

	for i=1, #result, 1 do
        local inventory = json.decode(result[i].inventory) or {}

        for k, item in ipairs(inventory) do
            MySQL.Sync.execute("INSERT INTO inventory_data (identifier, name, count, metadata, slot) VALUES (@identifier, @name, @count, @metadata, @slot)"
            , {
                ['@identifier'] = result[i].identifier,
                ['@name'] = item.name,
                ['@count'] = item.count,
                ['@metadata'] = json.encode(item.metadata),
                ['@slot'] = item.slot
            })
        end
    end

    print("Doneeee")
end, false)