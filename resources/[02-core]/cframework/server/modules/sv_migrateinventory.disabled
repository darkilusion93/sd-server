                name   = weapon.name,
                count = 1,
                metadata = {ammo = weapon.ammo, components = components},
                slot   = currentSlot
            })

            currentSlot += 1
        end

        MySQL.Async.execute('INSERT INTO inventories (identifier, inventory) VALUES (@identifier, @inventory)', {
            ['@inventory'] = json.encode(newInventory),
            ['@identifier'] = "society_"..identifier
        })
	end

    for i=1, #result, 1 do
        local identifier = result[i].name

        local items = MySQL.Sync.fetchAll('SELECT * FROM addon_inventory_items WHERE inventory_name = @identifier', {
            ['@identifier'] = "society_"..identifier.."_chefe"
        })

        local black_money = MySQL.Sync.fetchAll('SELECT * FROM addon_account_data WHERE account_name = @identifier', {
            ['@identifier'] = "society_"..identifier.."_chefe"
        })[1]

