RegisterNetEvent("cframework:trickOrTreat", function(index)
    local source = source

    math.randomseed(os.time()*13)

    local prize = math.random(1, 3)

    if not ESX.playerInsideLocation(source, trickOrTreatPeds, 10.0) then
        return
    end

    if index <= 0 or index > #trickOrTreatPeds then return end
    if trickOrTreatCooldown[source] == nil then trickOrTreatCooldown[source] = {} end

    local now = GetGameTimer()
    if trickOrTreatCooldown[source][index..""] ~= nil and now - trickOrTreatCooldown[source][index..""] <= 60000 then
        TriggerClientEvent("cframework:halloweenTrickTreatCooldown", source)
        return
    end

    trickOrTreatCooldown[source][index..""] = now

    if prize == 1 then
        ESX.addInventoryItem(source, "gums", math.random(4))
    elseif prize == 2 then
        ESX.addInventoryItem(source, "candy", math.random(4))
    elseif prize == 3 then
        ESX.addInventoryItem(source, "candle", math.random(4))
    end

    TriggerClientEvent("cframework:halloweenTrickTreatSubtitles", source, trickOrTreatMessages[math.random(1, #trickOrTreatMessages)], index, "treat")
end)

RegisterNetEvent("cframework:halloweenSpecial", function(index)
    local source = source

    math.randomseed(os.time()*13)

    if not ESX.playerInsideLocation(source, specialItemPeds, 10.0) then
        return
    end

    if index <= 0 or index > #specialItemPeds then return end
    if specialItemBlock[source] == nil then specialItemBlock[source] = 0 end

    if index < specialItemBlock[source] then
        TriggerClientEvent("cframework:halloweenBlockSpecial", source)
        return
    end

    if index == specialItemBlock[source] then
        TriggerClientEvent("cframework:halloweenTrickTreatSubtitles", source, specialItemMessages[index], index, "special")
        return
    end

    if index > specialItemBlock[source] + 1 then
        TriggerClientEvent("cframework:halloweenBlockNext", source)
        return
    end

    specialItemBlock[source] += 1

    if index == 7 then
        ESX.addInventoryItem(source, "halloween2025skull", 1)
    end

    TriggerClientEvent("cframework:halloweenTrickTreatSubtitles", source, specialItemMessages[index], index, "special")

    SetResourceKvp("halloween2024", json.encode(specialItemBlock))
end)