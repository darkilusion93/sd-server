local specialItemMessages = {
    "Estás a dar início ao evento Halloween Sem Destino 2025, tens mais 6 Spot para encontrar!",
    "Alguém se fez passar por morto, mas morto ele não estava! A casa dele deves investigar",
    "Ahhhh Mickel! Se o Trevor sabe... Sandy Shores será o destino.",
