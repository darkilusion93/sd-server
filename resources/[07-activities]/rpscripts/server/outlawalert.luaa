end)

RegisterServerEvent('esx_outlawalert:gunshotInProgress', function(targetCoords, streetName, playerGender)
	local mytype = 'police'
    local data = {["code"] = '10-13', ["name"] = 'TIROTEIO', ["loc"] = streetName}
    local length = 3500

    for k,v in ipairs(Config.WhitelistedCops) do
        for player, _ in pairs(ESX.getJobSourceList(v)) do
